# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-a-real-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ─────────────────────────────────────────────────
# Uncomment for PostgreSQL (required in production):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── CSRF (required in production for HTTPS) ──────────────────
# CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com

# ── Portal Scraper Credentials (local dev only) ─────────────
PORTAL_ADMIN_USERNAME=
PORTAL_ADMIN_PASSWORD=

# ── Optional / Dev-Only ──────────────────────────────────────
# ALLOW_DEV_ROLE_SWITCH=true
# ADVISOR_DB_PATH=path/to/legacy/advisor.db

# Optional Neo4j Timetable Graph Twin
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=change-me
# NEO4J_DATABASE=neo4j

# WhatsApp Advisor Gateway
# WHATSAPP_VERIFY_TOKEN=change-me-long-random-string
# WHATSAPP_APP_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_STUDENT_EMAIL_DOMAIN=
# WHATSAPP_OTP_TTL_SECONDS=300
# WHATSAPP_OTP_MAX_ATTEMPTS=5
# WHATSAPP_ALLOW_SUPER_ADMIN=false
# DEFAULT_FROM_EMAIL=advisor-bot@your-university.edu
