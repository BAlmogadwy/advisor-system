# ── Django Core ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-a-real-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ─────────────────────────────────────────────────
# Uncomment for PostgreSQL (required in production):
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── CSRF (required in production for HTTPS) ──────────────────
# CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com

# ── Portal Scraper Credentials (local dev only) ─────────────
PORTAL_ADMIN_USERNAME=
PORTAL_ADMIN_PASSWORD=

# ── Optional / Dev-Only ──────────────────────────────────────
# ALLOW_DEV_ROLE_SWITCH=true
# ADVISOR_DB_PATH=path/to/legacy/advisor.db
